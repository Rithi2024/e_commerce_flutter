# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# PayWay
PAYWAY_FUNCTION_NAME=payway-qr
PAYWAY_CALLBACK_URL=
PAYWAY_CURRENCY=USD
PAYWAY_QR_TEMPLATE=template3_color
PAYWAY_QR_LIFETIME_MINUTES=15

# Auth email function
AUTH_EMAIL_FUNCTION_NAME=resend-email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_BRAND_NAME=MarketFlow
WEB_SESSION_TIMEOUT_ENABLED=true
WEB_SESSION_TIMEOUT_MINUTES=30

# Support channels
SUPPORT_EMAIL=support@yourstore.com
SUPPORT_PHONE=+10000000000
SUPPORT_WHATSAPP_URL=
SUPPORT_TELEGRAM_URL=
SUPPORT_FACEBOOK_URL=
SUPPORT_MESSENGER_URL=
SUPPORT_STORE_LOCATION_URL=
SUPPORT_FAQ_URL=
SUPPORT_HOURS=Mon - Sun, 7:00 AM - 10:00 PM

# Backend proxies
BACKEND_PROXY_URL=/api/supabase-function-proxy
BACKEND_DATA_PROXY_URL=/api/supabase-data-proxy
BACKEND_PROXY_TIMEOUT_SECONDS=20
PROXY_ALLOWED_FUNCTIONS=
PROXY_ALLOWED_RPCS=
PROXY_ALLOWED_TABLES=

# Storefront sharing
STOREFRONT_PUBLIC_URL=

# Web Maps
GOOGLE_MAPS_WEB_API_KEY=

# Native Maps (Android build reads OS env first, then .env)
GOOGLE_MAPS_ANDROID_API_KEY=
